{
  "configVersion": "v3",
  "app": {
    "appId": 1023001,
    "appName": "RogueMeso Beacon",
    "appType": "app",
    "version": {
      "code": 15,
      "name": "0.10.0"
    },
    "icon": "icon.png",
    "vender": "roguemeso",
    "description": "RogueMeso wearable beacon: workout heart-rate tracking"
  },
  "permissions": [
    "data:os.device.info",
    "data:user.hd.heart_rate",
    "device:os.bg_service",
    "device:os.alarm"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.0",
      "minVersion": "3.0"
    }
  },
  "targets": {
    "common": {
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        },
        "app-service": {
          "services": [
            "app-service/minute-logger"
          ]
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        },
        {
          "st": "s",
          "dw": 390
        }
      ]
    }
  },
  "i18n": {
    "en-US": {
      "appName": "RogueMeso Beacon"
    }
  },
  "defaultLanguage": "en-US"
}