// RogueMeso — self-hosted hypertrophy training app.
// Reference data (muscle groups, exercises, templates) is loaded by the seed scripts:
// the base library from prisma/seed-data.sql (empty DB only), plus idempotent additive
// SQL applied on every boot (prisma/descriptions.sql, prisma/kettlebell.sql) so existing
// DBs gain new data. Mesocycles hold training blocks + logged sets, owned per user.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- Enums (stable, known value sets) -----

enum ExerciseType {
  machine
  barbell
  dumbbell
  cable
  freemotion
  smithMachine          @map("smith-machine")
  bodyweightOnly        @map("bodyweight-only")
  bodyweightLoadable    @map("bodyweight-loadable")
  machineAssistance     @map("machine-assistance")
  kettlebell
}

enum MgPriority {
  maintain
  grow
  emphasize
}

enum Unit {
  lb
  kg
}

// Status fields are kept as String (not DB enums) to stay flexible across the set/day/meso
// lifecycle (e.g. set: pendingWeight | pending | complete | skipped; day/meso: ready |
// current | complete ...). Avoids migration churn; values are validated in the app.

// ----- Single user (personal self-host) -----

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String?
  role         String   @default("user") // "admin" | "user" (see lib/roles.ts)
  // Soft account state. `active=false` blocks login AND invalidates live sessions
  // (getCurrentUser rejects inactive users), so deactivation is instant + reversible
  // without deleting the user's data. `mustChangePassword` forces a self-set password
  // on next login — set by an admin password reset, cleared by changeMyPassword.
  active             Boolean @default(true)
  mustChangePassword Boolean @default(false)
  // Bumped on every password change/reset to revoke all previously-issued session cookies
  // (the signed token carries this number; getCurrentUser rejects a stale one). Lets a
  // password change act as "sign out everywhere" even though sessions are otherwise stateless.
  sessionVersion     Int     @default(0)
  unit         Unit     @default(lb)
  heightCm      Float?
  birthDate     DateTime?
  bodySex       String?   // "M" | "F" — the person's sex (distinct from Template.sex)
  activityLevel String?   // "sedentary" | "light" | "moderate"
  goalWeightKg  Float?    // long-term target bodyweight (canonical kg); drives the trend projection
  // Physical Therapy Lens: opt-in (default OFF) to load-management & movement-quality tracking.
  // When false the set-logger and Insights are byte-for-byte the default experience — the capture
  // panel, the /insights/physical-therapy sub-route and its entry card are all gated on this flag.
  // Informational only, never medical advice; never mutates the training engine.
  physicalTherapyLens Boolean @default(false)
  // Community: opt-in to the instance social space (default OFF). When false the
  // user neither posts to the feed nor appears on leaderboards — every community
  // query filters on this flag, so opt-out is instant and reversible (no data loss).
  communityOptIn Boolean @default(false)
  // Last app version (git SHA, see APP_VERSION) whose "What's new" panel this user has
  // acknowledged. null = never seen the panel; baselined to the current version on first
  // load so a user only ever sees changes shipped *after* they started using it.
  lastSeenVersion String?
  // Wearables: sha256 of this user's beacon token (the credential the Zepp mini-app
  // presents to /api/wearables/zepp). Plaintext is shown once at generation and never
  // stored; null = no wearable paired. Regenerating/revoking replaces/clears the hash.
  zeppTokenHash String? @unique
  // Opt-in for the live Bluetooth (Web Bluetooth) heart-rate connection UI. Default OFF:
  // the connect pill/chooser only appear when enabled; watch-sync display is unaffected.
  bleHrEnabled Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mesocycles    Mesocycle[]
  exercises     Exercise[] // user-created custom exercises
  templates     Template[] // user-created templates
  weightEntries WeightEntry[]
  readinessEntries ReadinessEntry[] // daily recovery check-ins (Recovery hub)
  hrSamples     HrSample[] // wearable heart-rate readings captured during sessions
  wellnessSnapshots WellnessSnapshot[] // on-demand wellness syncs from the watch
  activities    Activity[] // community feed posts authored by this user
  reactions     Reaction[] // kudos this user gave

  // ADHD Mode (notification engine)
  pushSubscriptions    PushSubscription[]
  notificationSchedule NotificationSchedule?
  habitConfigs         HabitConfig[]
  reminderLogs         ReminderLog[]
}

// Append-only record of admin actions on users (role changes, resets, deactivations,
// deletions, edits). Deliberately NOT a relation: actor/target ids are bare ints and
// the human label is snapshotted, so a log row stays readable even after the actor or
// target is deleted.
model AuditLog {
  id           Int      @id @default(autoincrement())
  actorId      Int?
  actorLabel   String   // snapshot of the acting admin (name or email) at action time
  action       String   // e.g. "user.role.set", "user.deactivate", "user.password.reset"
  targetUserId Int?
  targetLabel  String?  // snapshot of the affected user
  detail       String?  // short human description, e.g. "user → admin"
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

// ----- Reference data -----

model MuscleGroup {
  id   Int    @id @default(autoincrement())
  sourceId Int    @unique          // stable reference id (1..12)
  name String @unique

  exercises        Exercise[]
  templateSlots    TemplateSlot[]
  templatePriority TemplatePriority[]
  mesoPriority     MesoPriority[]
  dayExercises     DayExercise[]
}

model Exercise {
  id            Int          @id @default(autoincrement())
  sourceId          Int?         @unique          // catalog reference id (null for custom)
  name          String
  muscleGroupId Int
  muscleGroup   MuscleGroup  @relation(fields: [muscleGroupId], references: [id])
  exerciseType  ExerciseType
  youtubeId     String?
  notes         String?
  // Physical Therapy Lens taxonomy (editable metadata, nullable = "Unclassified"). Seeded
  // idempotently from name+muscle by prisma/exercise-taxonomy.sql. `movementPattern` is one of
  // the PATTERN keys and `primaryJoints` is a JSON string[] of JOINT keys — see
  // src/lib/features/physicalTherapyTaxonomy.ts. Plain columns so a classification can be fixed.
  movementPattern String?
  primaryJoints   String?
  isCustom      Boolean      @default(false)
  userId        Int?         // null = shared catalog; set = creator's private exercise
  user          User?        @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())

  templateSlots TemplateSlot[]
  dayExercises  DayExercise[]

  @@index([muscleGroupId])
  @@index([name])
  @@index([userId])
}

// ----- Templates (program library) -----

model Template {
  id               Int    @id @default(autoincrement())
  sourceId             Int?   @unique
  key              String @unique          // stable slug
  name             String
  emphasis         String
  description      String?                 // optional protocol notes (how the program is run)
  sex              String
  frequency        Int?
  sourceTemplateId Int?                    // provenance (source ids), informational
  userId           Int?                    // null = shared library; set = user-created
  user             User?    @relation(fields: [userId], references: [id])
  // Community: a user-owned template (userId = me) with this true is browsable and
  // usable (copy-on-use) by other opted-in members. Seeded library (userId null) is
  // always shared and ignores this flag.
  sharedWithInstance Boolean @default(false)
  createdAt        DateTime @default(now())

  days       TemplateDay[]
  priorities TemplatePriority[]

  @@index([userId])
  @@index([sharedWithInstance])
}

model TemplateDay {
  id         Int      @id @default(autoincrement())
  templateId Int
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  position   Int
  label      String?  // optional day name (e.g. "Complex (ABC)", "Swings & Rows")

  slots TemplateSlot[]

  @@index([templateId])
}

model TemplateSlot {
  id            Int         @id @default(autoincrement())
  templateDayId Int
  templateDay   TemplateDay @relation(fields: [templateDayId], references: [id], onDelete: Cascade)
  position      Int
  muscleGroupId Int
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id])
  exerciseId    Int?
  exercise      Exercise?   @relation(fields: [exerciseId], references: [id])

  @@index([templateDayId])
}

model TemplatePriority {
  id            Int         @id @default(autoincrement())
  templateId    Int
  template      Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  muscleGroupId Int
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id])
  priority      MgPriority

  @@unique([templateId, muscleGroupId])
}

// ----- Mesocycles (training blocks + logged sets) -----

model Mesocycle {
  id               Int       @id @default(autoincrement())
  sourceId             Int?      @unique
  key              String    @unique
  userId           Int?
  user             User?     @relation(fields: [userId], references: [id])
  name             String
  daysPerWeek      Int
  weeksCount       Int
  unit             Unit      @default(lb)
  microRirs        Int?
  status           String    @default("ready")
  generatedFrom    String?
  sourceTemplateId Int?
  notes                String?
  nutritionGoal        String?   // "cut" | "bulk" | "maintain" — null treated as maintain
  targetRatePctPerWeek Float?    // optional signed override (fraction of BW/week)
  goalWeightKg         Float?    // target bodyweight for THIS block (canonical kg); cycle projection
  startedAt        DateTime?
  finishedAt       DateTime?
  // The single "active"/current block per user. Exactly one row per user is non-null (the
  // app enforces this in a transaction on activate/create); getActiveMeso prefers it.
  activeAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  priorities MesoPriority[]
  days       MesoDay[]

  @@index([userId])
}

model MesoPriority {
  id            Int         @id @default(autoincrement())
  mesoId        Int
  meso          Mesocycle   @relation(fields: [mesoId], references: [id], onDelete: Cascade)
  muscleGroupId Int
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id])
  priority      MgPriority

  @@unique([mesoId, muscleGroupId])
}

model MesoDay {
  id             Int       @id @default(autoincrement())
  mesoId         Int
  meso           Mesocycle @relation(fields: [mesoId], references: [id], onDelete: Cascade)
  week           Int                       // microcycle index (0-based)
  position       Int                       // day index within the week (0-based)
  label          String?
  status         String    @default("pending")
  bodyweight     Float?
  bodyweightUnit String?
  notes          String?
  // Session start: stamped by the first logged set (logSet, only when still null) so the
  // heart-rate capture window has a left edge. Cleared never — reopening a day keeps it.
  startedAt      DateTime?
  finishedAt     DateTime?

  exercises DayExercise[]
  checkIn   SessionCheckIn?
  hrSamples HrSample[]

  @@index([mesoId, week, position])
}

// ----- Wearables: live heart-rate capture -----
// One row per reading (~1 Hz) captured in the browser over Web Bluetooth (standard GATT
// Heart Rate service) during a session, batch-inserted every ~30s by logHrBatch. Scoped
// to the MesoDay so the intra-workout chart can join readings against ExerciseSet.finishedAt.
// ~5,400 rows per 90-minute session; cascade-deleted with the day.

model HrSample {
  id     Int      @id @default(autoincrement())
  userId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Nullable by design (recorder spec §1): rows from the on-watch recorder are
  // day-agnostic and get matched to a session at read time by time window; rows from
  // live browser capture keep the direct day link.
  dayId  Int?
  day    MesoDay? @relation(fields: [dayId], references: [id], onDelete: Cascade)
  at     DateTime // reading time (client clock, validated/skew-corrected server-side)
  bpm    Int

  @@index([dayId, at])
  @@index([userId, at])
}

// Wearables: one row per wellness snapshot synced on demand from the watch app.
// `payload` holds the whitelisted per-domain sections exactly as collected (sleep,
// stress, SpO2, activity, PAI, body temp, workouts, environment, device metadata) —
// schema-on-read by design: the watch API's shapes are firmware-dependent and still
// being characterized per device, so ingestion validates bounds (lib/wellness.ts)
// but deliberately does not normalize into columns yet.
model WellnessSnapshot {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectedAt DateTime // watch collection time, skew-corrected server-side
  payload     Json
  createdAt   DateTime @default(now())

  @@index([userId, collectedAt])
}

// Physical Therapy Lens: one movement-quality & symptom check-in per session (MesoDay).
// Split into a pre-workout "Recovery Check-In" (light: how you're arriving) and a post-session
// check-in (the full survey: how it went). One row per day; each half is upserted independently
// and left null until submitted. `*Locations`/`postQualityTags` are JSON string[]. Only written
// when the lens is ON — the whole row is absent for opted-out users, keeping the lens additive.
model SessionCheckIn {
  id    Int     @id @default(autoincrement())
  dayId Int     @unique
  day   MesoDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  // Pre — "Recovery Check-In"
  prePainScore     Int?      // 0–10 subjective pain on arrival
  prePainLocations String?   // JSON string[] of body-region keys
  preNote          String?
  preSubmittedAt   DateTime?

  // Post — "Session Check-In"
  postPainScore     Int?     // 0–10 pain during/after the session
  postPainLocations String?  // JSON string[] of body-region keys
  postPainTiming    String?  // "during" | "after" | "next-day"
  postRangeOfMotion String?  // "full" | "partial" | "short"
  postQualityTags   String?  // JSON string[] of quality-tag keys
  postNote          String?
  postSubmittedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DayExercise {
  id            Int         @id @default(autoincrement())
  dayId         Int
  day           MesoDay     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseId    Int
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])
  muscleGroupId Int
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id])
  position      Int
  jointPain     Int?        // 1–5, predates the Physical Therapy Lens; left for back-compat
  status        String      @default("pending")

  sets ExerciseSet[]

  @@index([dayId])
}

model ExerciseSet {
  id              Int         @id @default(autoincrement())
  dayExerciseId   Int
  dayExercise     DayExercise @relation(fields: [dayExerciseId], references: [id], onDelete: Cascade)
  position        Int
  setType         String      @default("regular")
  weight          Float?
  weightTarget    Float?
  weightTargetMin Float?
  weightTargetMax Float?
  reps            Int?
  repsTarget      Int?
  rir             Int?
  bodyweight      Float?     // user bodyweight logged for bodyweight-loadable sets
  unit            String?
  // Physical Therapy Lens: which side this set loaded. "left" | "right" | "bilateral"; null is
  // treated as bilateral. Only surfaced/written when the lens is ON; drives the symmetry view.
  side            String?
  status          String      @default("pendingWeight")
  finishedAt      DateTime?

  @@index([dayExerciseId])
}

model WeightEntry {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  weightKg   Float
  bodyFatPct Float?                       // 0..1 fraction
  // Minutes since LOCAL midnight at weigh-in (0..1439), captured client-side. Null for legacy
  // rows / unknown. Lets us bucket weigh-ins into AM (<720) vs PM and surface time-of-day drift.
  localMinutes Int?
  note       String?
  createdAt  DateTime @default(now())

  @@unique([userId, date])
}

// ----- Recovery hub -----
// A standalone, ADVISORY recovery utility: a curated routine library + a daily readiness
// check-in. The readiness score is informational only and NEVER mutates the training
// engine (progression.ts) — auto-regulation evidence is weak, so we surface a signal and
// let the user decide. Engine + cited constants live in src/lib/features/recovery.ts.

// One dated self-report per user per day, mirroring WeightEntry. `score` is the advisory
// 0–100 readiness value computed at write time (computeReadinessScore) so the home-screen
// chip can read it without re-running the engine. Sleep lives here as a field rather than
// its own model — it's an input to readiness, not a standalone tracker.
model ReadinessEntry {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  sleepHours Float                        // 0..24; the heaviest-weighted readiness input
  soreness   Int                          // 1 (none) .. 5 (very sore)
  energy     Int                          // 1 (drained) .. 5 (great)
  note       String?
  score      Int                          // advisory 0..100, computed at write time
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// Curated recovery-routine library — shared reference content (no userId), shipped via the
// idempotent prisma/recovery.sql seed wired into docker-entrypoint.sh, exactly like the
// kettlebell catalog. `sourceId` is the stable id the seed upserts on (band 920000–929999).
// `steps` is a RecoveryStep[] JSON blob ({ movement, durationSec, cue? }). Mobility/yoga
// routines carry a `guardrail` string — static stretching does not reduce DOMS, so they are
// framed as range-of-motion tools only (PMC5932411; Cochrane CD004577).
model RecoveryRoutine {
  id          Int      @id @default(autoincrement())
  sourceId    Int      @unique
  key         String   @unique
  name        String
  category    String   // "active_recovery" | "foam_rolling" | "mobility"
  durationMin Int
  bodyFocus   String   // "full_body" | "lower" | "upper" | "posterior"
  steps       Json     // RecoveryStep[]
  rationale   String
  citation    String
  guardrail   String?
  createdAt   DateTime @default(now())
}

// ----- ADHD Mode (notification / reminder engine) -----
// A new tab pushes science-based habit reminders (workout, meals+macros, caffeine,
// hydration, creatine, sleep, …) to the user's devices via Web Push. Reminder times
// are COMPUTED from NotificationSchedule anchors + per-habit tunables; the in-process
// scheduler (src/lib/scheduler.ts, started from instrumentation.ts) ticks each minute.

// One row per subscribed device (a user may install the PWA on several). The
// p256dh/auth keys are the RFC 8291 encryption material web-push needs to send.
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique          // push-service URL; also the device identity
  p256dh    String
  auth      String
  timezone  String   @default("UTC")  // IANA zone captured from the browser at subscribe
  userAgent String?                   // informational, helps the user identify a device
  createdAt DateTime @default(now())

  @@index([userId])
}

// Per-user daily-schedule anchors (LOCAL time) + global controls. One per user.
// Times are stored as HHMM integers (e.g. 2230 = 22:30) so the scheduler compares
// them directly to the user's current local clock with no zone math on the hot path.
model NotificationSchedule {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wakeHHMM      Int      @default(600)   // 06:00
  bedtimeHHMM   Int      @default(2230)  // 22:30
  workoutHHMM   Int?                     // null = rest day → training reminders skip today
  mealsPerDay   Int      @default(3)
  globalEnabled Boolean  @default(false) // master switch for all ADHD notifications
  dailyCap      Int      @default(20)    // max pushes/day across all habits (anti-spam)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Per-habit toggle + tunable params. `params` is a jsonb blob owned by the habit's
// registry entry (src/lib/features/adhdModeRegistry.ts), merged over registry
// defaults at runtime — so adding a new habit needs no migration.
model HabitConfig {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitKey  String   // matches a HabitDefinition.key
  enabled   Boolean  @default(true)
  params    Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@unique([userId, habitKey])
  @@index([userId])
}

// Idempotency + snooze ledger. One row per (user, habit, local day, firing). The
// unique constraint is the guard that a per-minute tick — or a mid-day restart —
// never double-sends. localDate is the user's LOCAL calendar date as a string so a
// UTC-midnight rollover can't shift a reminder onto the wrong day.
model ReminderLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitKey     String
  localDate    String    // "YYYY-MM-DD" in the user's timezone
  firingIndex  Int       // 0-based index into the habit's computeFireTimes() result
  snoozedUntil DateTime? // set when the user taps Snooze; tick re-fires once it passes
  sentAt       DateTime  @default(now())

  @@unique([userId, habitKey, localDate, firingIndex])
  @@index([userId, localDate])
}

// ----- Community (instance-local social) -----
// A lightweight, additive social layer for the handful of members on one self-hosted
// instance. Activities are written at the moment something happens (workout finished,
// PR hit, meso finished) and read back as a chronological feed + weekly leaderboard.
// Card display uses denormalized snapshot fields so a row still renders after the
// source meso/exercise is renamed or deleted. `dedupeKey` makes writes idempotent so
// re-editing a completed set never double-posts.

enum ActivityType {
  workoutComplete @map("workout_complete")
  prHit           @map("pr_hit")
  mesoComplete    @map("meso_complete")
}

model Activity {
  id           Int          @id @default(autoincrement())
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ActivityType
  dedupeKey    String       @unique          // e.g. "workout_complete:42", "pr_hit:7", "meso_complete:3"
  occurredAt   DateTime                       // real-world event time (not row insert time)
  // Denormalized display snapshot — written once, never joined back to source rows.
  mesoKey      String?                        // deep-link target when the meso still exists
  mesoName     String?
  exerciseName String?
  setsCount    Int?                           // workoutComplete: sets logged that day
  weeksCount   Int?                           // mesoComplete: block length
  prWeight     Float?                         // prHit: the lift
  prReps       Int?
  prOneRm      Float?                         // prHit: rounded estimated 1RM
  unit         String?                        // "lb" | "kg" for the numbers above
  createdAt    DateTime     @default(now())

  reactions    Reaction[]

  @@index([occurredAt(sort: Desc)])
  @@index([userId])
}

model Reaction {
  id         Int      @id @default(autoincrement())
  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji      String   // one of a small allowed set, validated in the action layer
  createdAt  DateTime @default(now())

  @@unique([activityId, userId, emoji]) // one of each emoji per person per activity
  @@index([activityId])
}
