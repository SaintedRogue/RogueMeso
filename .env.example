# Copy to .env and fill in. Never commit .env (it's gitignored).

# --- Database (these values feed docker-compose.yml and Prisma) ---
POSTGRES_USER=roguemeso
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=roguemeso
DATABASE_URL="postgresql://roguemeso:change-this-password@localhost:5432/roguemeso?schema=public"

# --- Auth ---
# Signs the session cookie. REQUIRED: the app refuses to run without a value of
# at least 32 characters (an empty/weak key would let anyone forge a session).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# --- Seeding & first admin (only needed when seeding a fresh database) ---
# Folder holding reference/ + templates/ + mesocycles/ JSON for the seed scripts.
SEED_DATA_DIR="/path/to/seed-data"
# The first (admin) account created by prisma/seed/createAdmin.ts.
ADMIN_EMAIL="you@example.com"
ADMIN_NAME="Admin"
ADMIN_PASSWORD="change-this-password"

# --- Web Push (ADHD Mode notifications) ---
# Required for push reminders. Generate a keypair with:
#   npx web-push generate-vapid-keys
# All three are RUNTIME env — the public key is served to the browser at runtime via
# /api/push/vapid-key (not baked into the build), so you can change keys without rebuilding.
# Keep the PRIVATE key server-only. VAPID_SUBJECT must be a mailto: or https: URL.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
